@inherits LayoutComponentBase
@using Datle.Shared

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <StreakBadge @ref="streakBadge" />
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private StreakBadge? streakBadge; // This matches the @ref name above

    public void NotifyStreakChanged() 
    {
        // Tell the badge to run its refresh logic
        streakBadge?.Refresh();
    }
}
