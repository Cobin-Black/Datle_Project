@page "/"

@using Datle.DataStructures
@using Datle.Models
@using Datle.Services
@inject ChallengeService ChallengeSvc
@inject VisualizerService VisualSvc
@inject StorageService StorageSvc

<PageTitle>Datle: Your Daily Data Structure Challenge</PageTitle>

@if (currentChallenge == null)
{
    <div class="d-flex justify-content-center mt-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <div class="container-fluid mt-3">
        <div class="row">
            <div class="col-md-8">
                <div class="text-center p-4 shadow-sm border rounded bg-white mb-4">
                    
                    <div class="visualizer-container mb-4 d-flex justify-content-center align-items-center" style="min-height: 250px; background-color: #f8f9fa; border-radius: 8px;">
                        @switch (currentChallenge.DSType)
                        {
                            case "SelectionSort":
                                <svg width="350" height="150">@((MarkupString)VisualSvc.DrawArray(sortLogic.Data, sortLogic.CurrentOuterIndex))</svg>
                                break;

                            case "BST":
                            case "Heap":
                            case "HeapSort":
                            case "PriorityQueue":
                                <svg width="400" height="220">
                                    @((MarkupString)VisualSvc.DrawTree(sortLogic.Data))
                                </svg>
                                break;

                            case "LinkedList":
                                <svg width="600" height="120">
                                    <defs>
                                        <marker id="arrowhead" markerWidth="10" markerHeight="7" refX="10" refY="3.5" orient="auto">
                                            <polygon points="0 0, 10 3.5, 0 7" fill="#333" />
                                        </marker>
                                    </defs>
                                    @((MarkupString)VisualSvc.DrawLinkedList(sortLogic.Data))
                                </svg>
                                break;

                            case "HashTable":
                                <svg width="200" height="200">@((MarkupString)VisualSvc.DrawHashTable(currentChallenge.DataString))</svg>
                                break;

                            case "Graphs":
                                <svg width="300" height="150">@((MarkupString)VisualSvc.DrawGraph(currentChallenge.DataString))</svg>
                                break;

                            case "Arrays":
                            case "CountingSort":
                            case "QuickSort":
                                <svg width="350" height="150">@((MarkupString)VisualSvc.DrawArray(sortLogic.Data, 0))</svg>
                                break;

                            case "MasterTheorem":
                                <div class="w-75">
                                    <div class="alert alert-info text-start mb-2" style="font-family: monospace; font-size: 0.85rem;">
                                        <strong>Reference:</strong><br />
                                        1: $f(n) = O(n^c), c &lt; \log_b a \Rightarrow \Theta(n^{\log_b a})$<br />
                                        2: $f(n) = \Theta(n^{\log_b a}) \Rightarrow \Theta(n^{\log_b a} \log n)$<br />
                                        3: $f(n) = \Omega(n^c), c > \log_b a \Rightarrow \Theta(f(n))$
                                    </div>
                                    <div class="math-formula py-2" style="font-size: 1.4rem;">$$T(n) = aT(n/b) + f(n)$$</div>
                                </div>
                                break;

                            default:
                                <div class="alert alert-secondary">Visual for @currentChallenge.DSType coming soon!</div>
                                break;
                        }
                    </div>

                    <h3 class="fw-bold">@currentChallenge.Title</h3>
                    <p class="lead">@currentChallenge.Question</p>

                    <div class="d-grid gap-2 d-md-flex justify-content-center mb-4">
                        @if (currentChallenge?.Options != null)
                        {
                            int i = 0;
                            @foreach (var option in currentChallenge.Options)
                            {
                                int index = i;
                                <button type="button"
                                        class="btn btn-lg @(selectedIndex == index ? "btn-primary" : "btn-outline-primary")"
                                        disabled="@hasAnswered"
                                        @onclick="() => SelectOption(index)">
                                    @option
                                </button>
                                i++;
                            }
                        }
                    </div>

                    <button type="button" class="btn btn-success btn-lg px-5 shadow-sm" 
                            @onclick="SubmitAnswer" 
                            disabled="@(selectedIndex == null || hasAnswered)">
                        Submit Answer
                    </button>

                    @if (hasAnswered)
                    {
                        <div class="alert @(isCorrect ? "alert-success" : "alert-danger") mt-4 shadow-sm animate__animated animate__fadeIn">
                            <h5 class="alert-heading">@(isCorrect ? "✨ Correct!" : "❌ Not quite...")</h5>
                            <hr>
                            <p class="mb-0">@currentChallenge.Explanation</p>
                        </div>
                    }
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-primary text-white fw-bold">
                        📅 Past Challenges
                    </div>
                        <div class="list-group list-group-flush" style="max-height: 550px; overflow-y: auto;">
                         @if (allDates.Any())
                        {
                            @foreach (var date in allDates)
                            {
                                <button class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" 
                                    @onclick="() => LoadChallenge(date)">
                                    <span>@date.ToString("MMM dd")</span>
                                    <span class="badge bg-light text-dark shadow-sm">View</span>
                                </button>
                            }
                        }
                        else
                        {
                            <div class="p-3 text-muted small">No past challenges found.</div>
                        }
                    </div>
                </div>
            </div>
        </div> @* End Row *@
    </div> @* End Container *@
}

@code {
    [CascadingParameter]
    public MainLayout? Layout { get; set; }

    private Challenge? currentChallenge;
    private int? selectedIndex; 
    private bool hasAnswered = false;
    private bool isCorrect = false;
    private int currentStreak = 0;

    private List<Challenge> pastChallenges = new();
    private SelectionSortLogic sortLogic = new();
    private List<DateTime> allDates = new();

    protected override async Task OnInitializedAsync()
    {
        // 1. Load today's challenge FIRST (this triggers the service to fill _cache)
        await LoadChallenge(DateTime.Today);

        // 2. NOW get the past challenges for the sidebar
        pastChallenges = ChallengeSvc.GetPastChallenges();
        allDates = pastChallenges.Select(c => c.Date).ToList();

        // 3. Calculate streak
        currentStreak = await StorageSvc.CalculateStreak(allDates);
    }

    private async Task LoadChallenge(DateTime date)
    {
        currentChallenge = await ChallengeSvc.GetChallengeByDate(date);

        if (currentChallenge != null)
        {
            sortLogic.LoadData(currentChallenge.DataString);
        
            var savedResult = await StorageSvc.GetProgress(date.ToString("yyyy-MM-dd"));
        
            hasAnswered = savedResult != null;
            isCorrect = savedResult ?? false;
        
            // Reset selection if not answered yet
            if (!hasAnswered) selectedIndex = null;
        
            // REFRESH THE SIDEBAR LIST
            allDates = ChallengeSvc.GetPastChallenges().Select(c => c.Date).ToList();
        }
    }

    private void SelectOption(int index)
    {
        if (hasAnswered) return;
        selectedIndex = index;
    }

    private async Task SubmitAnswer()
    {
        if (selectedIndex == null || hasAnswered) return;

        if (selectedIndex == currentChallenge!.CorrectOptionIndex)
        {
            isCorrect = true;
        }

        hasAnswered = true;

        // 1. Wait for the browser to finish writing to SessionStorage
        await StorageSvc.SaveProgress(currentChallenge.Date.ToString("yyyy-MM-dd"), isCorrect);
    
        // 2. Now that the data is definitely there, tell the top-right badge to look at it
        Layout?.NotifyStreakChanged();
    
        // 3. Update the local variable for the Home page too
        currentStreak = await StorageSvc.CalculateStreak(allDates);
        StateHasChanged();
    }
}