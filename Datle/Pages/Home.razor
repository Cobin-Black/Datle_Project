@page "/"


@using Datle.Models
@using Datle.Services
@inject ChallengeService ChallengeSvc
@inject VisualizerService VisualSvc

<PageTitle>Datle: Your Daily Data Structure Challenge</PageTitle>

@if (currentChallenge == null)
{
    <p>Loading Daily Challenge...</p>
}
else
{
    <div class="visualizer-box" style="border: 1px solid #ccc; padding: 20px; text-align: center; margin-bottom: 20px;">
        @switch (currentChallenge.DSType)
        {
            case "BST":
                <svg width="200" height="150">
                    @((MarkupString)VisualSvc.GenerateLine(100, 30, 50, 80))
                    @((MarkupString)VisualSvc.GenerateLine(100, 30, 150, 80))
                    @((MarkupString)VisualSvc.GenerateNodeSvg(100, 30, 10)) 
                    @((MarkupString)VisualSvc.GenerateNodeSvg(50, 80, 5))   
                    @((MarkupString)VisualSvc.GenerateNodeSvg(150, 80, 15)) 
                </svg>
                break;

            case "SelectionSort":
            case "HeapSort":
            case "CountingSort":
            case "Arrays":
                <svg width="300" height="150">
                    @((MarkupString)VisualSvc.DrawArray(new int[] { 5, 2, 8, 1, 9 }, 0))
                </svg>
                break;

            case "MasterTheorem":
                <div class="alert alert-info text-start" style="font-family: monospace; font-size: 0.9rem;">
                    <strong>Master Theorem Reference:</strong><br />
                    Case 1: If $f(n) = O(n^c)$ where $c \log_b a$, then $T(n) = \Theta(n^{\log_b a})$<br />
                    Case 2: If $f(n) = \Theta(n^{\log_b a})$, then $T(n) = \Theta(n^{\log_b a} \log n)$<br />
                    Case 3: If $f(n) = \Omega(n^c)$ where $c > \log_b a$, then $T(n) = \Theta(f(n))$
                </div>
                <div class="math-formula" style="font-size: 1.5rem; padding: 10px;">
                    $$T(n) = aT(n/b) + f(n)$$
                </div>
                break;

            default:
                <div class="alert alert-secondary">Visual representation for @currentChallenge.DSType coming soon!</div>
                break;
        }

    <h1>@currentChallenge.Title</h1>
            <p>@currentChallenge.Question</p>

            @foreach (var (option, index) in currentChallenge.Options.Select((v, i) => (v, i)))
            {
                <button class="btn @(selectedIndex == index ? "btn-primary" : "btn-outline-primary") m-2" 
                        @onclick="() => SelectOption(index)" 
                        disabled="@hasAnswered">
                    @option
                </button>
            }

            <div class="mt-4">
                @if (!hasAnswered) 
                {
                    <button class="btn btn-success btn-lg" 
                            @onclick="SubmitAnswer" 
                            disabled="@(selectedIndex == null)">
                        Submit Answer
                    </button>
                }
            </div>

            @if (hasAnswered) {
                <div class="alert @(isCorrect ? "alert-success" : "alert-danger") mt-3">
                    @currentChallenge.Explanation
                </div>
            }
    </div>

    <div class="col-md-4 border-start">
        <h4>Challenge History</h4>
    <div class="list-group" style="max-height: 500px; overflow-y: auto;">
        @if (pastChallenges != null)
        {
            @foreach (var oldChallenge in pastChallenges)
            {
                <button class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" 
                        @onclick="() => LoadChallenge(oldChallenge.Date)">
                    <div>
                        <strong>@oldChallenge.Date.ToShortDateString()</strong><br/>
                        <small class="text-muted">@oldChallenge.Title</small>
                    </div>
                    <span class="badge bg-secondary rounded-pill">@oldChallenge.DSType</span>
                </button>
            }
        }
    </div>
    </div>
}

@code {
    private Challenge? currentChallenge;
    private int? selectedIndex; // Tracks the clicked button
    private bool hasAnswered = false;
    private bool isCorrect = false;

    private List<Challenge> pastChallenges = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadChallenge(DateTime.Today);

        pastChallenges = ChallengeSvc.GetPastChallenges();
    }

    private async Task LoadChallenge(DateTime date)
    {
        // Reset state for the new question
        hasAnswered = false;
        isCorrect = false;
        selectedIndex = null;
    
        currentChallenge = await ChallengeSvc.GetChallengeByDate(date);
    }

    private void SelectOption(int index)
    {
        if (hasAnswered) return;
        selectedIndex = index; // Just highlights the button
    }

    private void SubmitAnswer()
    {
        if (currentChallenge == null || selectedIndex == null) return;
    
        hasAnswered = true;
        isCorrect = (selectedIndex == currentChallenge.CorrectOptionIndex);
    }
}